{
  "name": "f2tech-shared",
  "version": "0.11.0",
  "description": "Shared cross-project helpers for the F2 Tech web stack — single source of truth for TLD detection, per-TLD URL handling, opaque-sid SSO handoff, and per-customer agreements / data-tier flags so changes land in one place instead of N repos.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./tld": {
      "types": "./src/tld.d.ts",
      "import": "./src/tld.js"
    },
    "./agreements": {
      "types": "./src/agreements.d.ts",
      "import": "./src/agreements.js"
    },
    "./country-flags": {
      "types": "./src/country-flags.d.ts",
      "import": "./src/country-flags.js"
    },
    "./sid-handoff": {
      "types": "./src/sid-handoff.d.ts",
      "import": "./src/sid-handoff.js"
    },
    "./error-reports": {
      "types": "./src/error-reports.d.ts",
      "import": "./src/error-reports.js"
    },
    "./support-toast": {
      "types": "./src/support-toast.d.ts",
      "import": "./src/support-toast.js"
    }
  },
  "files": [
    "src/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/F2Tech-WebDev-v2/f2tech-shared.git"
  },
  "license": "UNLICENSED",
  "private": true
}
